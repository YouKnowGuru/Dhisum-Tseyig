# ============================================================================
# SECURITY WARNING: Never commit .env file with real credentials to version control!
# This file should be copied to .env and populated with actual values.
# Make sure .env is in your .gitignore file.
# ============================================================================

# Development Settings
# Disable Turbopack to prevent infinite compilation loops and high CPU usage
NEXT_TURBOPACK=0

# MongoDB
# SECURITY: Use a strong password and rotate regularly. Consider using MongoDB Atlas with IP whitelisting.
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# NextAuth
# SECURITY: Generate a strong random secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-super-secret-key-here-min-32-chars-random
NEXTAUTH_URL=http://localhost:3000

# AWS S3 / Cloudflare R2
# SECURITY: Use IAM roles with minimal permissions. Never use root account keys.
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=auto
AWS_BUCKET_NAME=dhisum-tseyig-downloads
AWS_ENDPOINT_URL=https://your-account.r2.cloudflarestorage.com

# SMTP Configuration
# SECURITY: Use app-specific passwords for Gmail. Enable 2FA on email account.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

# Admin Credentials (for seeding only)
# SECURITY: Change immediately after first login. Use strong unique password.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMeImmediately123!

# ============================================================================
# PRODUCTION SECURITY CHECKLIST:
# [ ] NEXTAUTH_SECRET is a strong random string (min 32 chars)
# [ ] MongoDB connection uses TLS/SSL
# [ ] Database user has minimal required permissions
# [ ] All passwords meet complexity requirements
# [ ] SMTP uses app-specific password, not account password
# [ ] AWS keys have least-privilege access
# [ ] .env file is in .gitignore
# [ ] NODE_ENV=production in production
# ============================================================================
